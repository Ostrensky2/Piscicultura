# Supabase — copie este arquivo para `.env` e preencha com os valores do seu projeto.
# NUNCA coloque aqui a senha do banco; apenas a URL e a chave PUBLICÁVEL (anon),
# que são seguras para o cliente.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
